# ── Backend (FastAPI) ─────────────────────────────────────
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/zomato_lens
SECRET_KEY=change-me-to-a-long-random-string-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=1440
ENVIRONMENT=development

# Email OTP delivery
# For Gmail, use an App Password, not your normal Gmail password.
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-16-character-app-password
MAIL_FROM=your-email@gmail.com
MAIL_PORT=587
MAIL_SERVER=smtp.gmail.com
MAIL_FROM_NAME=Foodlytics
MAIL_STARTTLS=True
MAIL_SSL_TLS=False


# ── Frontend (Vite) ───────────────────────────────────────
# Leave unset in dev — Vite proxies /api to localhost:8000
# VITE_API_URL=http://localhost:8000/api
